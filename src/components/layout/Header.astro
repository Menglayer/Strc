---
const pathname = Astro.url.pathname;
const navItems = [
    { href: '/ticker/strc', label: 'STRC行情' },
    { href: '/dividends', label: '分红' },
    { href: '/filings', label: 'SEC文件' },
    { href: '/tools', label: '工具' },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-dark/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-4 h-16">
        <div class="flex items-center gap-3">
            <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
                <img src="/logo-broadcast.svg" alt="盘盘STRC" class="w-10 h-10 logo-glow rounded" />
                <div>
                    <h1 class="font-display text-2xl font-bold leading-none tracking-wider">
                        <span class="text-btc">盘盘</span><span class="text-white">STRC</span>
                    </h1>
                    <p class="text-[11px] text-muted tracking-tight">BTC优先股收益终端</p>
                </div>
            </a>
        </div>

        <nav class="hidden lg:flex items-center gap-6">
            {navItems.map(item => (
                <a
                    href={item.href}
                    class:list={[
                        'text-sm font-medium transition-colors',
                        pathname.startsWith(item.href) ? 'text-white' : 'text-muted hover:text-white'
                    ]}
                >
                    {item.label}
                </a>
            ))}
        </nav>

        <div class="flex items-center gap-3">
            <a href="https://x.com/menglayer" target="_blank" rel="noopener noreferrer"
                class="hidden lg:flex items-center gap-2 bg-white/10 hover:bg-btc/20 border border-white/10 hover:border-btc/50 px-3 py-1.5 rounded-full transition-all duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
                <span class="text-sm font-medium">@menglayer</span>
            </a>
            <button class="lg:hidden p-2 text-muted hover:text-white transition-colors" aria-label="切换菜单">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </div>
</header>