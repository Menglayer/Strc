---
import Layout from '../../layouts/Layout.astro';
import { GlassCard } from '../../components/ui/GlassCard.tsx';
---

<Layout title="工具 - 盘盘STRC">
    <div class="max-w-6xl mx-auto px-4 py-8">
        <header class="mb-8">
            <h1 class="text-3xl font-bold font-display text-white">工具</h1>
            <p class="text-muted mt-2">收益率计算器与模型</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <a href="/tools/retirement" class="block">
                <GlassCard hover={true} className="h-full">
                    <h2 class="text-xl font-bold text-white mb-2">退休计算器</h2>
                    <p class="text-sm text-muted">估算STRC未来收益，规划退休。</p>
                </GlassCard>
            </a>

            <a href="/tools/sustainability" class="block">
                <GlassCard hover={true} className="h-full">
                    <h2 class="text-xl font-bold text-white mb-2">可持续性模型</h2>
                    <p class="text-sm text-muted">分析BTC支撑收益的可持续性。</p>
                </GlassCard>
            </a>

            <a href="/tools/dca" class="block">
                <GlassCard hover={true} className="h-full">
                    <h2 class="text-xl font-bold text-white mb-2">定投计算器</h2>
                    <p class="text-sm text-muted">模拟定期定额投资，计算累计股数与分红收入。</p>
                </GlassCard>
            </a>
        </div>
    </div>
</Layout>