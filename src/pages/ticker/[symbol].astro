---
import Layout from '../../layouts/Layout.astro';
import { TickerDetail } from '../../components/ticker/TickerDetail';
import { TICKERS, type TickerSymbol } from '../../lib/constants';

export function getStaticPaths() {
    return [
        { params: { symbol: 'strc' } },
    ];
}

const { symbol } = Astro.params;
const ticker = symbol.toUpperCase() as TickerSymbol;
const tickerInfo = TICKERS[ticker];
---

<Layout title={`${ticker} 实时行情 | ${tickerInfo.rate}% 收益率 - 盘盘STRC`}>
    <div class="max-w-6xl mx-auto px-4 py-6">
        <!-- 面包屑导航 -->
        <nav class="text-sm text-muted mb-4">
            <a href="/" class="hover:text-white transition-colors">首页</a>
            <span class="mx-2">&gt;</span>
            <span class="text-white font-bold">{ticker} 行情</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-3xl font-bold font-display text-white">{ticker} 实时行情</h1>
            <p class="text-sm text-muted mt-1">{tickerInfo.name} — 实时ATM活动与比特币购入追踪</p>
        </header>

        <TickerDetail client:load symbol={ticker} />
    </div>
</Layout>
